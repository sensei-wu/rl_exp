   "source": [
    "import gymnasium as gym\n",
    "\n",
    "env_names = [\n",
    "    \"FrozenLake-v1\",\n",
    "    \"Taxi-v3\",\n",
    "    \"CliffWalking-v0\",\n",
    "    \"CartPole-v1\",\n",
    "]\n",
    "\n",
    "for name in env_names:\n",
    "    env = gym.make(name)\n",
    "    print(f\"{name:30s}  action_space.n = {env.action_space.n}\")\n",
    "    env.close()"
   ]
  }
 ],
